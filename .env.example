# =============================================================================
# Clinica.app — Environment Variables
# =============================================================================
# Copie este arquivo para .env.local e preencha os valores.
#   cp .env.example .env.local
# =============================================================================

# ─── Supabase ───────────────────────────────────────────────────────────────

# URL do projeto Supabase (encontrada em: Settings > API > Project URL)
# Exemplo: https://seuprojeto.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Chave anônima (pública) do Supabase — pode ser exposta ao cliente com segurança
# Encontrada em: Settings > API > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ⚠️  Chave de serviço (service_role) do Supabase.
#     Esta chave TEM PODER TOTAL sobre o seu banco de dados e NUNCA deve ser
#     exposta ao cliente (não use em componentes React ou no navegador).
#     Use apenas em Server Actions, Route Handlers, ou scripts de migração.
#     Encontrada em: Settings > API > service_role (mantenha em segredo!)
SUPABASE_SERVICE_ROLE_KEY=

# ─── App ────────────────────────────────────────────────────────────────────

# URL pública da aplicação (usada em links de redirecionamento e emails)
# Exemplos:
#   Desenvolvimento: http://localhost:3000
#   Produção:        https://clinica.app
NEXT_PUBLIC_APP_URL=
